<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title><%= player.username %> — Forsaken Tide</title><link rel="stylesheet" href="/style.css"><link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚓</text></svg>"></head>
<body>
<div class="bg"></div>
<nav class="nav">
  <div class="nav-logo">FORSAKEN TIDE <span>leaderboard</span></div>
  <div class="nav-links">
    <a href="/">Leaderboard</a>
    <a href="/info">Info</a>
    <% if (user) { %>
      <a href="/matches">Matches</a>
      <a href="/profile/<%= user.id %>" class="active">Profile</a>
      <% if (isAdmin) { %><a href="/admin">Admin</a><% } %>
      <div class="nav-user">
        <img class="nav-avatar" src="<%= user.avatar_url %>"><span class="nav-username"><%= user.username %></span>
        <a href="/logout" class="btn btn-outline btn-sm">Logout</a>
      </div>
    <% } else { %>
      <a href="/login" class="btn btn-gold">◆ Login with Discord</a>
    <% } %>
  </div>
</nav>

<section class="profile">
  <div class="profile-header">
    <div class="avatar-container" style="flex-shrink:0"><img class="profile-avatar" src="<%= player.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"><% if (player.region) { %><span class="region-flag" style="bottom:0;right:0;font-size:9px"><%= player.region %></span><% } %></div>
    <div>
      <div class="profile-name">
        <span class="<%= admins.includes(player.discord_id) ? 'player-name-admin' : '' %>"><%= player.username %></span><% if (player.verified && !admins.includes(player.discord_id)) { %><span class="verified-badge" style="display:inline-flex;vertical-align:middle;">✓</span><% } %><% if (admins.includes(player.discord_id)) { %><span class="admin-badge">✓</span><% } %>
        <a href="https://discord.com/users/<%= player.discord_id %>" target="_blank" class="profile-link profile-link-discord" title="Discord Profile"><svg viewBox="0 0 127.14 96.36" width="24" height="24"><path fill="#5865F2" d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg></a>
        <% if (player.roblox_username) { %><a href="https://www.roblox.com/user.aspx?username=<%= player.roblox_username %>" target="_blank" class="profile-link profile-link-roblox" title="Roblox Profile"><img src="/roblox-icon.png" width="24" height="24" style="border-radius:4px;vertical-align:middle"></a><% } %>
      </div>
      <div class="profile-build"><%= player.rank ? '◈ ' + player.rank : '' %><%= player.roblox_username ? ' · ⛓ ' + player.roblox_username : '' %><%= player.region ? ' · 🌍 ' + player.region : '' %><%= player.build ? ' · ⚔ ' + player.build : '' %><%= player.build_items ? ' — ' + player.build_items : '' %></div>
    </div>
  </div>

  <div class="profile-stats">
    <div class="stat-card"><div class="stat-card-value"><%= player.elo_display || player.elo %></div><div class="stat-card-label">ELO</div></div>
    <div class="stat-card"><div class="stat-card-value"><%= player.rank %></div><div class="stat-card-label">Rank</div></div>
    <div class="stat-card"><div class="stat-card-value">F<%= player.fraction %></div><div class="stat-card-label">Fraction</div></div>
    <div class="stat-card"><div class="stat-card-value"><%= player.wins %></div><div class="stat-card-label">Wins</div></div>
    <div class="stat-card"><div class="stat-card-value"><%= player.losses %></div><div class="stat-card-label">Losses</div></div>
    <div class="stat-card"><div class="stat-card-value"><%= player.wins + player.losses > 0 ? Math.round(player.wins / (player.wins + player.losses) * 100) : 0 %>%</div><div class="stat-card-label">Win Rate</div></div>
    <div class="stat-card"><div class="stat-card-value"><%= player.current_streak || 0 %><span style="font-size:14px;color:#5a5a4a"> (<%= player.max_streak || 0 %>)</span></div><div class="stat-card-label">Streak (Best)</div></div>
  </div>

  <% if (activeSeason) { %>
    <div class="settings-section" style="text-align:center;padding:16px;">
      <span style="font-size:13px;color:#FFD700;font-weight:700">◈ <%= activeSeason.name %><% if (activeSeason.is_preparation) { %><span style="color:#5a5a4a;font-weight:400;margin-left:6px">— Preparation Season</span><% } %></span>
    </div>
  <% } %>

  <div class="profile-section-title">◉ ELO History</div>
  <div class="settings-section">
    <canvas id="eloChart" width="700" height="200" style="width:100%;height:200px;display:block"></canvas>
    <div id="eloNoData" style="color:#5a5a4a;text-align:center;padding:30px;display:none">No ELO history yet. Play matches to see your progression!</div>
  </div>

  <% if (user && user.id === player.id) { %>
    <div class="settings-section">
      <div class="profile-section-title">◆ Edit Profile</div>
      <div class="form-group"><label>Roblox Username</label><input class="form-input" id="robloxInput" value="<%= player.roblox_username || '' %>" placeholder="Your Roblox username"></div>
      <div class="form-group"><label>Region (auto-detected from Discord roles)</label><div class="form-input" style="background:#1a1a1a;padding:10px 14px;border-radius:8px;color:#ccc"><%= player.region || 'No region role assigned' %></div></div>
      <div class="form-group"><label>Build Type</label><select class="form-input" id="buildInput"><option value="Normal" <%= player.build === 'Normal' ? 'selected' : '' %>>Normal</option><option value="Skilled" <%= player.build === 'Skilled' ? 'selected' : '' %>>Skilled</option></select></div>
      <div class="form-group"><label>Items / Build</label><input class="form-input" id="buildItemsInput" value="<%= player.build_items || '' %>" placeholder="e.g. Shark + Godhuman + Soul Guitar"></div>
      <button class="btn btn-gold" onclick="saveProfile()">Save</button>
    </div>
  <% } %>

  <div class="profile-section-title">◉ Match History</div>
  <% if (matchHistory.length === 0) { %><div style="color:#5a5a4a;padding:20px;text-align:center;">No matches yet.</div><% } %>
  <% matchHistory.forEach(m => { const p1Won = m.winner_id === m.player1_id; %>
    <div class="match-row">
      <div><% if (player.id === m.player1_id) { %><span class="<%= p1Won ? 'match-winner' : 'match-loser' %>">vs <%= m.p2_name %></span><% } else { %><span class="<%= !p1Won ? 'match-winner' : 'match-loser' %>">vs <%= m.p1_name %></span><% } %></div>
      <div style="color:#5a5a4a;font-size:0.85em"><%= m.winner_score %>-<%= m.loser_score %></div>
      <div><span class="<%= (player.id === m.player1_id ? m.player1_elo_change : m.player2_elo_change) >= 0 ? 'match-elo-plus' : 'match-elo-minus' %>"><%= (player.id === m.player1_id ? m.player1_elo_change : m.player2_elo_change) >= 0 ? '+' : '' %><%= player.id === m.player1_id ? m.player1_elo_change : m.player2_elo_change %></span><span class="match-date"> <%= new Date(m.played_at).toLocaleDateString() %></span></div>
      <% if (isAdmin) { %>
        <div style="display:flex;gap:6px;align-items:center;margin-left:8px">
          <button class="btn btn-sm btn-edit" onclick="editMatch(<%= m.id %>, <%= m.winner_score %>, <%= m.loser_score %>)" title="Edit scores">✎</button>
          <button class="btn btn-sm btn-delete" onclick="deleteMatch(<%= m.id %>)" title="Delete match">✕</button>
        </div>
      <% } %>
    </div>
  <% }) %>
</section>
<footer class="footer">Forsaken Tide Leaderboard &nbsp;|&nbsp; Built by ValTheOneAndOnly ❤️</footer>
<a href="https://discord.gg/jK4RmZgr86" target="_blank" class="discord-link" title="Join our Discord"><svg viewBox="0 0 127.14 96.36" width="28" height="28"><path fill="#5865F2" d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg></a>
<script src="/script.js"></script>
<script>
function editMatch(id, ws, ls) {
  showModal('Edit Match Scores', `
    <div class="form-group"><label>Winner Score</label><input class="form-input" id="wsInput" value="${ws}" type="number" min="0" max="10"></div>
    <div class="form-group"><label>Loser Score</label><input class="form-input" id="lsInput" value="${ls}" type="number" min="0" max="9"></div>
  `, [
    { text: 'Cancel', class: 'btn-outline', action: closeModal },
    { text: 'Save', class: 'btn-gold', action: async () => {
      const r = await fetch('/api/admin/update-match', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, winner_score: +document.getElementById('wsInput').value, loser_score: +document.getElementById('lsInput').value })
      });
      const d = await r.json();
      if (d.success) { showToast('Match updated!'); setTimeout(() => location.reload(), 1000); }
      else showToast(d.error || 'Failed', 'error');
    }}
  ]);
}
function deleteMatch(id) {
  showModal('Delete Match', 'Are you sure you want to delete this match?', [
    { text: 'Cancel', class: 'btn-outline', action: closeModal },
    { text: 'Delete', class: 'btn-delete', action: async () => {
      const r = await fetch('/api/admin/delete-match', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
      });
      const d = await r.json();
      if (d.success) { showToast('Match deleted!'); setTimeout(() => location.reload(), 1000); }
      else showToast(d.error || 'Failed', 'error');
    }}
  ]);
}

fetch('/api/elo-history/' + <%= player.id %>)
  .then(r => r.json())
  .then(data => {
    if (!data || data.length < 1) {
      document.getElementById('eloNoData').style.display = 'block';
      return;
    }
    const canvas = document.getElementById('eloChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);
    const W = rect.width, H = rect.height;

    const vals = data.map(d => parseInt(d.elo));
    const dataMin = Math.min(...vals);
    const dataMax = Math.max(...vals);
    const min = Math.max(0, dataMin - Math.max(10, (dataMax - dataMin) * 0.2));
    const max = dataMax + Math.max(10, (dataMax - dataMin) * 0.2);
    const range = max - min || 1;

    const pad = { top: 12, bottom: 20, left: 8, right: 8 };
    const cw = W - pad.left - pad.right;
    const ch = H - pad.top - pad.bottom;

    const cx = pad.left + cw / 2;

    function x(i) { return vals.length === 1 ? cx : pad.left + (i / (vals.length - 1)) * cw; }
    function y(v) { return pad.top + ch - ((v - min) / range) * ch; }

    // Hover tooltip
    const tip = document.createElement('div');
    tip.style.cssText = 'position:absolute;background:#101019;border:1px solid rgba(255,215,0,0.3);border-radius:6px;padding:6px 10px;font-size:12px;color:#FFD700;pointer-events:none;display:none;z-index:10;white-space:nowrap;font-weight:600';
    canvas.parentElement.style.position = 'relative';
    canvas.parentElement.appendChild(tip);
    canvas.addEventListener('mousemove', (e) => {
      const cr = canvas.getBoundingClientRect();
      const mx = e.clientX - cr.left;
      let closest = 0, minDist = Infinity;
      for (let i = 0; i < vals.length; i++) {
        const d = Math.abs(x(i) - mx);
        if (d < minDist) { minDist = d; closest = i; }
      }
      const cxPt = x(closest);
      if (Math.abs(cxPt - mx) < 20) {
        tip.style.display = 'block';
        tip.style.left = (cxPt + 10) + 'px';
        tip.style.top = (y(vals[closest]) - 30) + 'px';
        tip.textContent = vals[closest] + ' ELO' + (data[closest].recorded_at ? ' — ' + new Date(data[closest].recorded_at).toLocaleDateString() : '');
      } else {
        tip.style.display = 'none';
      }
    });
    canvas.addEventListener('mouseleave', () => { tip.style.display = 'none'; });

    // Grid lines
    ctx.strokeStyle = 'rgba(255,215,0,0.06)';
    ctx.lineWidth = 1;
    for (let i = 0; i < 4; i++) {
      const gy = pad.top + (ch / 3) * i;
      ctx.beginPath();
      ctx.moveTo(pad.left, gy);
      ctx.lineTo(W - pad.right, gy);
      ctx.stroke();
    }

    if (vals.length > 1) {
      // Area fill
      ctx.beginPath();
      ctx.moveTo(x(0), y(vals[0]));
      for (let i = 1; i < vals.length; i++) ctx.lineTo(x(i), y(vals[i]));
      ctx.lineTo(x(vals.length - 1), H - pad.bottom);
      ctx.lineTo(x(0), H - pad.bottom);
      ctx.closePath();
      const grad = ctx.createLinearGradient(0, pad.top, 0, H - pad.bottom);
      grad.addColorStop(0, 'rgba(255,215,0,0.25)');
      grad.addColorStop(1, 'rgba(255,215,0,0.01)');
      ctx.fillStyle = grad;
      ctx.fill();

      // Line
      ctx.beginPath();
      ctx.moveTo(x(0), y(vals[0]));
      for (let i = 1; i < vals.length; i++) ctx.lineTo(x(i), y(vals[i]));
      ctx.strokeStyle = '#FFD700';
      ctx.lineWidth = 2;
      ctx.lineJoin = 'round';
      ctx.stroke();
    }

    // Dots
    ctx.beginPath();
    ctx.arc(x(0), y(vals[0]), 3, 0, Math.PI * 2);
    ctx.fillStyle = '#FFD700';
    ctx.fill();
    // Show current ELO label
    ctx.fillStyle = '#888';
    ctx.font = '12px monospace';
    ctx.textAlign = 'center';
    ctx.fillText(vals[vals.length - 1] + ' ELO', cx, H - 4);
  })
  .catch(() => { document.getElementById('eloNoData').style.display = 'block'; });
</script>
</body></html>
