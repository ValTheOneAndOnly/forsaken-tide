<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title><%= player.username %> — Forsaken Tide</title><link rel="stylesheet" href="/style.css"><link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚓</text></svg>"></head>
<body>
<div class="bg"></div>
<nav class="nav">
  <div class="nav-logo">FORSAKEN TIDE <span>leaderboard</span></div>
  <div class="nav-links">
    <a href="/">Leaderboard</a>
    <a href="/info">Info</a>
    <% if (user) { %>
      <a href="/profile/<%= user.id %>" class="active">Profile</a>
      <% if (isAdmin) { %><a href="/admin">Admin</a><% } %>
      <div class="nav-user">
        <img class="nav-avatar" src="<%= user.avatar_url %>"><span class="nav-username"><%= user.username %></span>
        <a href="/logout" class="btn btn-outline btn-sm">Logout</a>
      </div>
    <% } else { %>
      <a href="/login" class="btn btn-gold">◆ Login with Discord</a>
    <% } %>
  </div>
</nav>

<section class="profile">
  <div class="profile-header">
    <img class="profile-avatar" src="<%= player.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png' %>">
    <div>
      <div class="profile-name">
        <%= player.username %><% if (player.verified) { %><span class="verified-badge" style="display:inline-flex;vertical-align:middle;">✓</span><% } %>
        <a href="https://discord.com/users/<%= player.discord_id %>" target="_blank" class="profile-link profile-link-discord" title="Discord Profile"><svg viewBox="0 0 127.14 96.36" width="18" height="18"><path fill="#5865F2" d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg></a>
        <% if (player.roblox_username) { %><a href="https://www.roblox.com/user.aspx?username=<%= player.roblox_username %>" target="_blank" class="profile-link profile-link-roblox" title="Roblox Profile"><img src="data:image/jpeg;base64," width="18" height="18" style="border-radius:4px;vertical-align:middle"></a><% } %>
      </div>
      <div class="profile-build"><%= player.rank ? '◈ ' + player.rank : '' %><%= player.roblox_username ? ' · ⛓ ' + player.roblox_username : '' %><%= player.build ? ' · ⚔ ' + player.build : '' %><%= player.build_items ? ' — ' + player.build_items : '' %></div>
    </div>
  </div>

  <div class="profile-stats">
    <div class="stat-card"><div class="stat-card-value"><%= player.elo %></div><div class="stat-card-label">ELO</div></div>
    <div class="stat-card"><div class="stat-card-value"><%= player.rank %></div><div class="stat-card-label">Rank</div></div>
    <div class="stat-card"><div class="stat-card-value">F<%= player.fraction %></div><div class="stat-card-label">Fraction</div></div>
    <div class="stat-card"><div class="stat-card-value"><%= player.wins %></div><div class="stat-card-label">Wins</div></div>
    <div class="stat-card"><div class="stat-card-value"><%= player.losses %></div><div class="stat-card-label">Losses</div></div>
    <div class="stat-card"><div class="stat-card-value"><%= player.wins + player.losses > 0 ? Math.round(player.wins / (player.wins + player.losses) * 100) : 0 %>%</div><div class="stat-card-label">Win Rate</div></div>
  </div>

  <% if (user && user.id === player.id) { %>
    <div class="settings-section">
      <div class="profile-section-title">◆ Edit Profile</div>
      <div class="form-group"><label>Roblox Username</label><input class="form-input" id="robloxInput" value="<%= player.roblox_username || '' %>" placeholder="Your Roblox username"></div>
      <div class="form-group"><label>Build Type</label><select class="form-input" id="buildInput"><option value="Normal" <%= player.build === 'Normal' ? 'selected' : '' %>>Normal</option><option value="Skilled" <%= player.build === 'Skilled' ? 'selected' : '' %>>Skilled</option></select></div>
      <div class="form-group"><label>Items / Build</label><input class="form-input" id="buildItemsInput" value="<%= player.build_items || '' %>" placeholder="e.g. Shark + Godhuman + Soul Guitar"></div>
      <button class="btn btn-gold" onclick="saveProfile()">Save</button>
    </div>
  <% } %>

  <div class="profile-section-title">◉ Match History</div>
  <% if (matchHistory.length === 0) { %><div style="color:#5a5a4a;padding:20px;text-align:center;">No matches yet.</div><% } %>
  <% matchHistory.forEach(m => { const p1Won = m.winner_id === m.player1_id; %>
    <div class="match-row">
      <div><% if (player.id === m.player1_id) { %><span class="<%= p1Won ? 'match-winner' : 'match-loser' %>">vs <%= m.p2_name %></span><% } else { %><span class="<%= !p1Won ? 'match-winner' : 'match-loser' %>">vs <%= m.p1_name %></span><% } %></div>
      <div style="color:#5a5a4a;font-size:0.85em"><%= m.winner_score %>-<%= m.loser_score %></div>
      <div><span class="<%= (player.id === m.player1_id ? m.player1_elo_change : m.player2_elo_change) >= 0 ? 'match-elo-plus' : 'match-elo-minus' %>"><%= (player.id === m.player1_id ? m.player1_elo_change : m.player2_elo_change) >= 0 ? '+' : '' %><%= player.id === m.player1_id ? m.player1_elo_change : m.player2_elo_change %></span><span class="match-date"> <%= new Date(m.played_at).toLocaleDateString() %></span></div>
    </div>
  <% }) %>
</section>
<footer class="footer">Forsaken Tide Leaderboard &nbsp;|&nbsp; Built by ValTheOneAndOnly ❤️</footer>
<a href="https://discord.gg/jK4RmZgr86" target="_blank" class="discord-link" title="Join our Discord"><svg viewBox="0 0 127.14 96.36" width="28" height="28"><path fill="#5865F2" d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg></a>
<script src="/script.js"></script>
</body></html>
