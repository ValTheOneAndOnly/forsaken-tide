<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Leaderboard — Forsaken Tide</title><link rel="stylesheet" href="/style.css"><link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚓</text></svg>"></head>
<body>
<div class="bg"></div>
<nav class="nav">
  <div class="nav-logo">FORSAKEN TIDE <span>leaderboard</span></div>
  <div class="nav-links">
    <a href="/">Leaderboard</a>
    <a href="/info">Info</a>
    <% if (user) { %>
      <a href="/profile/<%= user.id %>" class="active">Profile</a>
      <div class="nav-user">
        <img class="nav-avatar" src="<%= user.avatar_url %>"><span class="nav-username"><%= user.username %></span>
        <a href="/logout" class="btn btn-outline btn-sm">Logout</a>
      </div>
    <% } else { %>
      <a href="/login" class="btn btn-gold">◆ Login with Discord</a>
    <% } %>
  </div>
</nav>

<section class="leaderboard-section" style="padding-top:40px;">
  <div class="section-title">⚔ Full Leaderboard <span><%= total %> players</span></div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>#</th><th>Player</th><th>Rank</th><th>Fraction</th><th>Region</th><th>Build</th><th>ELO</th><th>W/L</th><th>Win Rate</th></tr></thead>
      <tbody>
        <% if (players.length === 0) { %><tr><td colspan="9" style="text-align:center;padding:40px;color:#5a5a4a;">No players yet.</td></tr><% } %>
        <% players.forEach((p, i) => { const rank = (page - 1) * 50 + i + 1; %>
          <tr>
            <td class="rank-cell rank-<%= rank <= 3 ? rank : '' %>"><%= rank %></td>
            <td><div class="player-cell"><div class="avatar-container"><img class="player-avatar" src="<%= p.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"><% if (p.region) { %><span class="region-flag"><%= p.region %></span><% } %></div><div><a href="/profile/<%= p.id %>" class="player-name<%= admins.includes(p.discord_id) ? ' player-name-admin' : '' %>"><%= p.username %><% if (p.verified && !admins.includes(p.discord_id)) { %><span class="verified-badge">✓</span><% } %><% if (admins.includes(p.discord_id)) { %><span class="admin-badge">✓</span><% } %></a></div></div></td>
            <td><span class="rank-badge"><%= p.rank %></span></td>
            <td><span class="frac-badge">F<%= p.fraction %></span></td>
            <td><%= p.region || '—' %></td>
            <td class="player-build"><%= p.build || '—' %><%= p.build_items ? ' — ' + p.build_items : '' %></td>
            <td class="elo-cell"><%= p.elo_display || p.elo %></td>
            <td><%= p.wins %>W / <%= p.losses %>L</td>
            <td class="wr-cell"><%= p.wins + p.losses > 0 ? Math.round(p.wins / (p.wins + p.losses) * 100) : 0 %>%</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (pages > 1) { %>
    <div class="pagination">
      <% if (page > 1) { %><a href="/leaderboard?page=<%= page - 1 %>">← Prev</a><% } %>
      <% for (let i = Math.max(1, page - 2); i <= Math.min(pages, page + 2); i++) { %><a href="/leaderboard?page=<%= i %>" class="<%= i === page ? 'active' : '' %>"><%= i %></a><% } %>
      <% if (page < pages) { %><a href="/leaderboard?page=<%= page + 1 %>">Next →</a><% } %>
    </div>
  <% } %>
</section>
<footer class="footer">Forsaken Tide Leaderboard &nbsp;|&nbsp; Built by ValTheOneAndOnly ❤️</footer>
