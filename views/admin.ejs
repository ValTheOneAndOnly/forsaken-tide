<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Admin — Forsaken Tide</title><link rel="stylesheet" href="/style.css"><link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚓</text></svg>"></head>
<body>
<div class="bg"></div>
<nav class="nav">
  <div class="nav-logo">FORSAKEN TIDE <span>admin</span></div>
  <div class="nav-links">
    <a href="/">Leaderboard</a>
    <a href="/info">Info</a>
    <a href="/profile/<%= user.id %>">Profile</a>
    <a href="/admin" class="active">Admin</a>
    <div class="nav-user">
      <img class="nav-avatar" src="<%= user.avatar_url %>"><span class="nav-username"><%= user.username %></span>
      <a href="/logout" class="btn btn-outline btn-sm">Logout</a>
    </div>
  </div>
</nav>

<section class="leaderboard-section" style="padding-top:40px;">
  <div class="section-title">◆ Admin Panel <span>manage players</span></div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>ID</th><th>Username</th><th>ELO</th><th>W/L</th><th>Actions</th></tr></thead>
      <tbody>
        <% players.forEach(p => { %>
          <tr>
            <td style="color:#5a5a4a;"><%= p.id %></td>
            <td><%= p.username %></td>
            <td class="elo-cell"><input class="form-input" style="width:80px;padding:4px 8px;" id="elo_<%= p.id %>" value="<%= p.elo %>" <%= user.username !== 'valtheoneandonly' ? 'readonly' : '' %>></td>
            <td><input class="form-input" style="width:50px;padding:4px 8px;" id="wins_<%= p.id %>" value="<%= p.wins %>" <%= user.username !== 'valtheoneandonly' ? 'readonly' : '' %>> / <input class="form-input" style="width:50px;padding:4px 8px;" id="losses_<%= p.id %>" value="<%= p.losses %>" <%= user.username !== 'valtheoneandonly' ? 'readonly' : '' %>></td>
            <td>
              <button class="btn btn-gold btn-sm" onclick="updateUser(<%= p.id %>)" <%= user.username !== 'valtheoneandonly' ? 'disabled' : '' %>>Save</button>
              <button class="btn btn-sm" style="background:rgba(255,68,102,0.15);color:#FF4466;border:1px solid rgba(255,68,102,0.3);" onclick="deleteUser(<%= p.id %>)">Delete</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
<footer class="footer">Forsaken Tide Admin &nbsp;|&nbsp; Built by ValTheOneAndOnly ❤️</footer>
<a href="https://discord.gg/jK4RmZgr86" target="_blank" class="discord-link" title="Join our Discord"><svg viewBox="0 0 127.14 96.36" width="28" height="28"><path fill="#5865F2" d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg></a>
<script>
function updateUser(id) {
  const elo = document.getElementById('elo_' + id).value;
  const wins = document.getElementById('wins_' + id).value;
  const losses = document.getElementById('losses_' + id).value;
  fetch('/api/admin/update-user', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: parseInt(id), elo: parseInt(elo), wins: parseInt(wins), losses: parseInt(losses) }),
  }).then(r => r.json()).then(d => { if (d.success) location.reload(); });
}
function deleteUser(id) {
  if (!confirm('Delete user ' + id + '?')) return;
  fetch('/api/admin/delete-user', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: parseInt(id) }),
  }).then(r => r.json()).then(d => { if (d.success) location.reload(); });
}
</script>
</body></html>
