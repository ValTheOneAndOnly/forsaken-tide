<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Forsaken Tide — Blox Fruits Competitive</title><link rel="stylesheet" href="/style.css"><link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚓</text></svg>"></head>
<body>
<div class="bg"></div>
<nav class="nav">
  <div class="nav-logo">FORSAKEN TIDE <span>leaderboard</span></div>
  <div class="nav-links">
    <a href="/" class="active">Leaderboard</a>
    <a href="/info">Info</a>
    <% if (user) { %>
      <a href="/profile/<%= user.id %>">Profile</a>
      <% if (isAdmin) { %><a href="/admin">Admin</a><% } %>
      <div class="nav-user">
        <img class="nav-avatar" src="<%= user.avatar_url %>"><span class="nav-username"><%= user.username %></span>
        <a href="/logout" class="btn btn-outline btn-sm">Logout</a>
      </div>
    <% } else { %>
      <a href="/login" class="btn btn-gold">◆ Login with Discord</a>
    <% } %>
  </div>
</nav>

<section class="hero">
  <h1>FORSAKEN TIDE</h1>
  <p>Blox Fruits Competitive 1v1 Leaderboard — Rise through the ranks</p>
  <div class="hero-stats">
    <div class="stat"><div class="stat-value"><%= total %></div><div class="stat-label">Players</div></div>
    <div class="stat"><div class="stat-value"><%= matches %></div><div class="stat-label">Matches</div></div>
    <div class="stat"><div class="stat-value">ELO</div><div class="stat-label">Ranking</div></div>
  </div>
</section>

<section class="leaderboard-section">
  <div class="section-title">⚔ Leaderboard <span>top 100</span></div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>#</th><th>Player</th><th>Rank</th><th>Fraction</th><th>Build</th><th>ELO</th><th>W/L</th><th>Win Rate</th></tr></thead>
      <tbody>
        <% if (top.length === 0) { %><tr><td colspan="8" style="text-align:center;padding:40px;color:#5a5a4a;">No players yet. Login with Discord to join!</td></tr><% } %>
        <% top.forEach((p, i) => { %>
          <tr>
            <td class="rank-cell rank-<%= i < 3 ? i + 1 : '' %>"><%= i + 1 %></td>
            <td><div class="player-cell"><img class="player-avatar" src="<%= p.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"><div><a href="/profile/<%= p.id %>" class="player-name"><%= p.username %><% if (p.verified) { %><span class="verified-badge">✓</span><% } %></a></div></div></td>
            <td><span class="rank-badge"><%= p.rank %></span></td>
            <td><span class="frac-badge">F<%= p.fraction %></span></td>
            <td class="player-build"><%= p.build || '—' %><%= p.build_items ? ' — ' + p.build_items : '' %></td>
            <td class="elo-cell"><%= p.elo %></td>
            <td><%= p.wins %>W / <%= p.losses %>L</td>
            <td class="wr-cell"><%= p.wins + p.losses > 0 ? Math.round(p.wins / (p.wins + p.losses) * 100) : 0 %>%</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="pagination"><a href="/leaderboard?page=1">View Full Leaderboard →</a></div>
</section>

<footer class="footer">Forsaken Tide — Community Blox Fruits Competitive Rankings &nbsp;|&nbsp; Built by ValTheOneAndOnly ❤️</footer>
