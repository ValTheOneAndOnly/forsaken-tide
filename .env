# ─── REQUIRED ───
# Go to https://discord.com/developers/applications → New Application
# → Bot → Create Bot → Copy Token
DISCORD_TOKEN=your_bot_token_here

# OAuth2 → General → Copy Client ID
CLIENT_ID=your_discord_client_id_here

# OAuth2 → Client Secret → Copy
CLIENT_SECRET=your_discord_client_secret_here

# OAuth2 → Add Redirect: http://localhost:3000/auth/discord/callback
# (change to your real domain when deploying)
REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Your Discord user ID (for admin panel access)
ADMIN_ID=your_discord_user_id_here

# Your Discord server (guild) ID for bot commands
GUILD_ID=your_discord_server_id_here

# ─── OPTIONAL ───
PORT=3000
SESSION_SECRET=change_this_to_something_random
SERVER_URL=http://localhost:3000
